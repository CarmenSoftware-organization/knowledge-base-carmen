# # ==============================================================================
# # GLOBAL CONFIGURATION (Project Root)
# # ==============================================================================

# # --- ENVIRONMENT ---
# # Options: development, production
# ENVIRONMENT=development

# # --- LLM PROVIDERS CONFIGURATION ---
# # Options: openrouter, zai, ollama
# ACTIVE_LLM_PROVIDER=openrouter

# # OpenRouter
# OPENROUTER_BASE_URL=https://openrouter.ai
# OPENROUTER_CHAT_MODEL='google/gemini-2.0-flash-lite-001'
# OPENROUTER_API_KEY=your_openrouter_api_key_here

# # Z.ai
# ZAI_API_BASE=https://api.z.ai/api/coding/paas/v4
# ZAI_CHAT_MODEL='glm-5'
# ZAI_API_KEY=your_zai_api_key_here

# # Ollama (Local)
# OLLAMA_URL=http://localhost:11434
# OLLAMA_CHAT_MODEL='gemma3:1b'
# OLLAMA_EMBED_MODEL=nomic-embed-text:latest

# # Google
# GOOGLE_API_KEY=your_google_api_key_here

# # --- DATA PROCESSING (Chunking) ---
# WIKI_CHUNK_SIZE=2000
# WIKI_CHUNK_OVERLAP=200

# # --- DATABASE (PostgreSQL with pgvector) ---
# DB_HOST=your-db-host
# DB_PORT=5432
# DB_USER=your-db-user
# DB_PASSWORD=your-db-password
# DB_NAME=your-db-name
# DB_SSLMODE=require

# # ==============================================================================
# # BACKEND (Go Fiber) CONFIGURATION
# # ==============================================================================
# SERVER_PORT=8080

# # --- GITHUB CONFIG ---
# GITHUB_REPO_OWNER=your_github_username
# GITHUB_REPO_NAME=your_repo_name
# GITHUB_BRANCH=wiki-content
# GITHUB_TOKEN=your_github_token_here
# GITHUB_WEBHOOK_BRANCH=wiki-content
# GITHUB_WEBHOOK_SECRET=your_webhook_secret_here

# # --- GIT & WIKI ---
# GIT_REPO_PATH=./wiki-content
# GIT_REPO_URL=https://github.com/your/repo.git
# WIKI_CONTENT_PATH=../carmen_cloud

# # ==============================================================================
# # CARMEN CHATBOT (Python / FastAPI) CONFIGURATION
# # ==============================================================================

# # --- DIRECTORIES ---
# FRONTEND_DIR=carmen-chatbot/carmen-chatbot-widget/dist
# IMAGES_DIR=carmen-chatbot/images

# # --- SYSTEM & SECURITY ---
# USER_AGENT=CarmenChatbot/1.0
# # Set to your main website URL in production, e.g., https://manual.yourcompany.com
# CORS_ORIGINS=*
# RATE_LIMIT_PER_MINUTE=20/minute
# DB_POOL_SIZE=10
# DB_MAX_OVERFLOW=20











