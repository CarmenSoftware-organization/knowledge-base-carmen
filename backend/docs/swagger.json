{
    "swagger": "2.0",
    "info": {
        "description": "REST API for wiki, FAQ, native RAG chat, indexing, activity, and GitHub webhooks. Most routes accept optional `bu` query or `X-BU-Slug` header (default from server config).",
        "title": "Knowledge base carmen API",
        "contact": {},
        "version": "1.0"
    },
    "basePath": "/",
    "paths": {
        "/api/activity/list": {
            "get": {
                "description": "Returns the activity log entries for the business unit.",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "activity"
                ],
                "summary": "Activity log list",
                "parameters": [
                    {
                        "type": "string",
                        "default": "carmen",
                        "description": "Business unit slug",
                        "name": "bu",
                        "in": "query"
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "type": "object",
                            "additionalProperties": true
                        }
                    }
                }
            }
        },
        "/api/activity/summary": {
            "get": {
                "description": "Returns aggregated activity statistics for the business unit.",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "activity"
                ],
                "summary": "Activity summary",
                "parameters": [
                    {
                        "type": "string",
                        "default": "carmen",
                        "description": "Business unit slug",
                        "name": "bu",
                        "in": "query"
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "type": "object",
                            "additionalProperties": true
                        }
                    }
                }
            }
        },
        "/api/business-units": {
            "get": {
                "description": "Lists the business units (tenants) available for the BU selector, excluding internal auto-provision entries.",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "wiki"
                ],
                "summary": "List business units",
                "parameters": [
                    {
                        "type": "string",
                        "default": "carmen",
                        "description": "Business unit slug",
                        "name": "bu",
                        "in": "query"
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "type": "object",
                            "additionalProperties": true
                        }
                    }
                }
            }
        },
        "/api/chat/ask": {
            "post": {
                "description": "Non-streaming RAG chat: retrieves relevant chunks and returns a grounded answer with its sources. Returns a \"no information found\" message when nothing matches.",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "chat"
                ],
                "summary": "Ask the knowledge-base chat (Go path)",
                "parameters": [
                    {
                        "type": "string",
                        "default": "carmen",
                        "description": "Business unit slug",
                        "name": "bu",
                        "in": "query"
                    },
                    {
                        "description": "Question",
                        "name": "body",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/models.ChatAskRequest"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/models.ChatAskResponse"
                        }
                    },
                    "400": {
                        "description": "Bad Request",
                        "schema": {
                            "type": "object",
                            "additionalProperties": true
                        }
                    }
                }
            }
        },
        "/api/chat/clear/{room_id}": {
            "delete": {
                "description": "Acknowledges a request to clear a chat room. No-op server-side — chat history is owned by the frontend.",
                "tags": [
                    "chat"
                ],
                "summary": "Clear room history (no-op ack; history is frontend-owned)",
                "responses": {}
            }
        },
        "/api/chat/feedback/{message_id}": {
            "post": {
                "description": "Records a thumbs up/down score for a chat message, scoped to the requesting user.",
                "tags": [
                    "chat"
                ],
                "summary": "Message feedback (thumbs up/down)",
                "responses": {}
            }
        },
        "/api/chat/history/list": {
            "get": {
                "security": [
                    {
                        "AdminKey": []
                    }
                ],
                "description": "Returns recent chat history rows, optionally filtered by business unit. Requires the X-Admin-Key header.",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "chat"
                ],
                "summary": "List chat history (admin)",
                "parameters": [
                    {
                        "type": "string",
                        "description": "Filter by BU",
                        "name": "bu",
                        "in": "query"
                    },
                    {
                        "type": "integer",
                        "default": 50,
                        "description": "Max rows",
                        "name": "limit",
                        "in": "query"
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "type": "object",
                            "additionalProperties": true
                        }
                    },
                    "401": {
                        "description": "Unauthorized",
                        "schema": {
                            "type": "object",
                            "additionalProperties": {
                                "type": "string"
                            }
                        }
                    }
                }
            }
        },
        "/api/chat/record-history": {
            "post": {
                "security": [
                    {
                        "InternalKey": []
                    }
                ],
                "description": "Persists a chat turn (question, answer, sources) to history. Internal-only; requires the X-Internal-API-Key header.",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "chat"
                ],
                "summary": "Record chat turn (internal)",
                "parameters": [
                    {
                        "description": "History row",
                        "name": "body",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/models.RecordHistoryRequest"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "type": "object",
                            "additionalProperties": true
                        }
                    },
                    "401": {
                        "description": "Unauthorized",
                        "schema": {
                            "type": "object",
                            "additionalProperties": {
                                "type": "string"
                            }
                        }
                    }
                }
            }
        },
        "/api/chat/route-test": {
            "post": {
                "security": [
                    {
                        "AdminKey": []
                    }
                ],
                "description": "Debug endpoint that returns only the intent-router decision for a question, without generating an answer. Requires the X-Admin-Key header.",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "chat"
                ],
                "summary": "Route-only debug (admin)",
                "parameters": [
                    {
                        "type": "string",
                        "default": "carmen",
                        "description": "Business unit slug",
                        "name": "bu",
                        "in": "query"
                    },
                    {
                        "description": "Question",
                        "name": "body",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/models.ChatAskRequest"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/models.RouteResult"
                        }
                    }
                }
            }
        },
        "/api/chat/stream": {
            "post": {
                "description": "Streaming RAG chat over NDJSON: emits status, sources, answer chunks, suggestions, and a final done event. This is the primary endpoint used by the frontend.",
                "tags": [
                    "chat"
                ],
                "summary": "Stream chat (native NDJSON RAG)",
                "responses": {}
            }
        },
