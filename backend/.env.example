SERVER_PORT=8080
SERVER_HOST=0.0.0.0
PORT=8080
ENVIRONMENT=development
STRICT_ENV_ONLY=false
# Local dev frontends: Next.js (frontend-next) :3301, React SPA (frontend-react) :3302
CORS_ORIGINS=http://localhost:3301,http://127.0.0.1:3301,http://localhost:3302,http://127.0.0.1:3302
ADMIN_API_KEY=replace-with-openssl-rand-hex-32
INTERNAL_API_KEY=replace-with-openssl-rand-hex-32
PRIVACY_HMAC_SECRET=replace-with-openssl-rand-hex-32
JWT_SECRET=replace-with-openssl-rand-hex-32
JWT_EXPIRY=24h
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=carmen_db
DB_SSLMODE=disable
DB_SCHEMA=carmen,public
VECTOR_DIMENSION=1536
GITHUB_TOKEN=ghp_REPLACE_WITH_YOUR_GITHUB_FINE_GRAINED_OR_CLASSIC_TOKEN
GITHUB_REPO_OWNER=Sunshine050
GITHUB_REPO_NAME=new-carmen
GITHUB_REPO_BASE_URL=https://github.com
GITHUB_API_BASE_URL=https://api.github.com
GITHUB_BRANCH=main
GITHUB_WEBHOOK_BRANCH=wiki-content
GITHUB_WEBHOOK_SECRET=replace-with-openssl-rand-hex-16
GIT_REPO_PATH=./wiki-content
GIT_REPO_URL=https://github.com/Sunshine050/new-carmen.git
GIT_SYNC_BRANCH=wiki-content
WIKI_DEFAULT_BU=carmen
WIKI_CARMEN_PATHS=../carmen_cloud,./carmen_cloud
WIKI_CARMEN_GIT_PATH=carmen_cloud
WIKI_CHUNK_SIZE=500
WIKI_CHUNK_OVERLAP=100
WIKI_SEARCH_LIMIT=20
WIKI_VECTOR_DISTANCE_MAX=0.3
WIKI_SNIPPET_MAX_LEN=200
CHAT_CONTEXT_LIMIT=10
CHAT_MAX_CONTEXT_CHARS=8000
CHAT_MAX_CHUNK_CONTENT=2000
CHAT_HISTORY_ENABLED=true
CHAT_HISTORY_SIMILARITY_THRESHOLD=0.15
INDEXING_TIMEOUT_MINUTES=60
WEBHOOK_INDEXING_TIMEOUT_MINUTES=30
TRANSLATION_ENABLED=true
GOOGLE_TRANSLATE_API_KEY=
TRANSLATION_API_BASE_URL=https://translation.googleapis.com/language/translate/v2
TRANSLATION_TIMEOUT_SECONDS=30
LLM_API_KEY=sk-or-v1-REPLACE_WITH_OPENROUTER_KEY
