# External Postgres+pgvector (no local db container).
# host.docker.internal = a Postgres running on the Docker host; or set a remote host.
DB_HOST=host.docker.internal
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=carmen_db
DB_SSLMODE=disable
BACKEND_PORT=8080
ENVIRONMENT=development
CORS_ORIGINS=*
JWT_SECRET=change-me-long-random-string
PRIVACY_HMAC_SECRET=changeme-use-openssl-rand-hex-32-in-production
DB_SCHEMA=carmen,public
WIKI_CONTENT_PATH=/repo/carmen_cloud
GITHUB_REPO_OWNER=Sunshine050
GITHUB_REPO_NAME=new-carmen
GITHUB_BRANCH=main
GITHUB_TOKEN=
OPENROUTER_API_KEY=
OPENROUTER_EMBED_MODEL=qwen/qwen3-embedding-8b
LLM_CHAT_MODEL=stepfun/step-3.5-flash:free
LLM_INTENT_MODEL=google/gemini-2.5-flash-lite
LLM_API_BASE=https://openrouter.ai/api/v1
GOOGLE_TRANSLATE_API_KEY=
TRANSLATION_ENABLED=false
