# =============================================================================
# Fly.io / production — คัดลอกไปใส่ Dashboard หรือ: fly secrets import
#
# คุณต้องหา/ใส่เอง (ไม่มีใน repo):
#   DB_PASSWORD          — รหัส PostgreSQL จริง
#   GITHUB_TOKEN         — สร้างที่ GitHub → Settings → Developer settings → Tokens
#   GITHUB_WEBHOOK_SECRET — สุ่มเอง แล้วใส่ตรงกันใน Repo → Settings → Webhooks → Secret
#   OPENROUTER_API_KEY + LLM_API_KEY — ใส่ค่าเดียวกัน (OpenRouter)
#   GOOGLE_TRANSLATE_API_KEY — ถ้า TRANSLATION_ENABLED=true ต้องเป็น key แบบ AIza...
#                              หรือตั้ง TRANSLATION_ENABLED=false แล้วเว้น GOOGLE_TRANSLATE_API_KEY ว่าง
#
# แก้ URL ให้ตรงของคุณ:
#   CORS_ORIGINS         — URL เว็บ frontend (ห้าม * ตอน production)
#   PYTHON_CHATBOT_URL   — URL บอท Python จริง เมื่อมี
# =============================================================================

DB_HOST=your-db-host.example.com
DB_PORT=5432
DB_USER=your_user
DB_PASSWORD=REPLACE_WITH_REAL_DB_PASSWORD
DB_NAME=your_database
DB_SSLMODE=require
DB_SCHEMA=carmen,public

ENVIRONMENT=production
STRICT_ENV_ONLY=false
SERVER_PORT=8080
SERVER_HOST=0.0.0.0

JWT_SECRET=REPLACE_WITH_openssl_rand_hex_32
JWT_EXPIRY=24h
PRIVACY_HMAC_SECRET=REPLACE_WITH_openssl_rand_hex_32
ADMIN_API_KEY=REPLACE_WITH_random_hex
INTERNAL_API_KEY=REPLACE_WITH_random_hex

# ห้ามใช้ * — ใส่โดเมน Vercel จริง (หลายตัวคั่นด้วยคอมมาได้ถ้าโค้ดรองรับ)
CORS_ORIGINS=https://carmen-kb-web.vercel.app

PYTHON_CHATBOT_URL=https://your-chatbot.fly.dev

LLM_API_KEY=sk-or-v1-REPLACE_WITH_OPENROUTER
OPENROUTER_API_KEY=sk-or-v1-REPLACE_WITH_OPENROUTER
LLM_API_BASE=https://openrouter.ai/api/v1
LLM_CHAT_MODEL=openai/gpt-4o-mini
OPENROUTER_CHAT_MODEL=openai/gpt-4o-mini
LLM_EMBED_MODEL=qwen/qwen3-embedding-8b
OPENROUTER_EMBED_MODEL=qwen/qwen3-embedding-8b
LLM_TIMEOUT_SECONDS=60

GITHUB_TOKEN=ghp_REPLACE_WITH_YOUR_TOKEN
GITHUB_REPO_OWNER=Sunshine050
GITHUB_REPO_NAME=new-carmen
GITHUB_REPO_BASE_URL=https://github.com
GITHUB_API_BASE_URL=https://api.github.com
GITHUB_BRANCH=main
GITHUB_WEBHOOK_BRANCH=main
GITHUB_WEBHOOK_SECRET=REPLACE_WITH_SECRET_AND_MATCH_GITHUB_WEBHOOK

GIT_REPO_URL=https://github.com/Sunshine050/new-carmen.git
GIT_REPO_PATH=/app/wiki-content
WIKI_CONTENT_PATH=/app/wiki-content
GIT_SYNC_BRANCH=main
WIKI_DEFAULT_BU=carmen
WIKI_CARMEN_PATHS=/app/carmen_cloud
WIKI_CARMEN_GIT_PATH=carmen_cloud
WIKI_CHUNK_SIZE=500
WIKI_CHUNK_OVERLAP=100
WIKI_SEARCH_LIMIT=20
WIKI_VECTOR_DISTANCE_MAX=0.3
WIKI_SNIPPET_MAX_LEN=200

CHAT_CONTEXT_LIMIT=10
CHAT_MAX_CONTEXT_CHARS=8000
CHAT_MAX_CHUNK_CONTENT=2000
CHAT_HISTORY_ENABLED=true
CHAT_HISTORY_SIMILARITY_THRESHOLD=0.15
INDEXING_TIMEOUT_MINUTES=60
WEBHOOK_INDEXING_TIMEOUT_MINUTES=30

VECTOR_DIMENSION=1536

TRANSLATION_ENABLED=false
GOOGLE_TRANSLATE_API_KEY=
TRANSLATION_API_BASE_URL=https://translation.googleapis.com/language/translate/v2
TRANSLATION_TIMEOUT_SECONDS=30
